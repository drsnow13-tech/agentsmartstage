import type { VercelRequest, VercelResponse } from '@vercel/node';
import { Resend } from 'resend';

export default async function handler(req: VercelRequest, res: VercelResponse) {
  if (req.method !== 'POST') return res.status(405).json({ error: 'Method not allowed' });

  const { email, roomType, enhancementId, enhancementLabel, tileIndex, notes } = req.body;

  if (!email) return res.status(400).json({ error: 'Email required' });

  try {
    const resend = new Resend(process.env.RESEND_API_KEY);

    // Email to Darren
    await resend.emails.send({
      from: 'StageSmart.ai <noreply@smartstageagent.com>',
      to: 'darren@smartstageagent.com',
      subject: `🚨 Bad Result Report — ${roomType || 'Unknown'} / ${enhancementLabel || enhancementId || 'Unknown'}`,
      html: `
        <div style="font-family: sans-serif; max-width: 600px;">
          <h2 style="color: #dc2626;">Bad Result Reported</h2>
          <table style="border-collapse: collapse; width: 100%;">
            <tr><td style="padding: 8px; font-weight: bold; border-bottom: 1px solid #e5e7eb;">Agent Email</td><td style="padding: 8px; border-bottom: 1px solid #e5e7eb;">${email}</td></tr>
            <tr><td style="padding: 8px; font-weight: bold; border-bottom: 1px solid #e5e7eb;">Room Type</td><td style="padding: 8px; border-bottom: 1px solid #e5e7eb;">${roomType || 'Not detected'}</td></tr>
            <tr><td style="padding: 8px; font-weight: bold; border-bottom: 1px solid #e5e7eb;">Enhancement</td><td style="padding: 8px; border-bottom: 1px solid #e5e7eb;">${enhancementLabel || enhancementId || 'Unknown'}</td></tr>
            <tr><td style="padding: 8px; font-weight: bold; border-bottom: 1px solid #e5e7eb;">Tile Version</td><td style="padding: 8px; border-bottom: 1px solid #e5e7eb;">Version ${(tileIndex ?? 0) + 1}</td></tr>
            ${notes ? `<tr><td style="padding: 8px; font-weight: bold; border-bottom: 1px solid #e5e7eb;">Agent Notes</td><td style="padding: 8px; border-bottom: 1px solid #e5e7eb;">${notes}</td></tr>` : ''}
          </table>
          <p style="color: #6b7280; font-size: 14px; margin-top: 16px;">Reply directly to the agent at ${email} to resolve.</p>
        </div>
      `,
    });

    // Confirmation email to agent
    await resend.emails.send({
      from: 'StageSmart.ai <noreply@smartstageagent.com>',
      to: email,
      subject: 'We received your report — StageSmart.ai',
      html: `
        <div style="font-family: sans-serif; max-width: 400px; margin: 0 auto; text-align: center;">
          <h2 style="color: #1E3A8A;">StageSmart.ai</h2>
          <p>We received your report about a ${roomType || ''} ${enhancementLabel || 'enhancement'} result that didn't meet expectations.</p>
          <p>Darren will review it personally and either fix the photo or add a credit to your account within 24 hours.</p>
          <p style="color: #6b7280; font-size: 14px;">Thank you for helping us improve.</p>
        </div>
      `,
    });

    return res.json({ success: true });
  } catch (err) {
    console.error('Report error:', err);
    return res.status(500).json({ error: 'Failed to send report' });
  }
}
